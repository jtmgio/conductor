# Conductor — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.template .env

# === Required ===

# PostgreSQL connection string
# Local dev: postgresql://conductor:localdev@localhost:5432/conductor
# Docker:    postgresql://conductor:localdev@localhost:5433/conductor (mapped port)
DATABASE_URL=postgresql://conductor:localdev@localhost:5432/conductor

# NextAuth session secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# NextAuth base URL
NEXTAUTH_URL=http://localhost:3000

# Anthropic API key — get from https://console.anthropic.com
# Can also be set in-app via Settings > System > API Keys
ANTHROPIC_API_KEY=

# === Optional ===

# App password hash (bcrypt) — set automatically during onboarding
# Only needed if pre-configuring outside the setup wizard
# APP_PASSWORD_HASH=

# File upload directory
UPLOAD_DIR=./uploads

# Postgres password — used by docker-compose.yml (default: localdev)
# POSTGRES_PASSWORD=localdev

# Granola API key — required for meeting transcript sync
# Get from Granola Settings > API (Business plan required)
# GRANOLA_API_KEY=

# Linear sync secret — shared secret for cron sync authentication
# LINEAR_SYNC_SECRET=conductor-linear-sync

# Timezone — IANA timezone for schedule block matching (default: America/New_York)
# TIMEZONE=America/New_York
