generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserProfile {
  id                     String   @id @default("default")
  displayName            String   @default("")
  communicationStyle     String?
  sampleMessages         String?
  globalContext           String?
  calendarIgnorePatterns String?
  calendarRoleMappings   String?
  passwordHash           String?
  anthropicApiKey        String?
  openaiApiKey           String?
  granolaApiKey          String?
  aiRecentNotesCount         Int?
  aiRecentTranscriptsCount   Int?
  aiConversationHistoryLimit Int?
  aiNoteChunkSize            Int?
  aiTranscriptChunkSize      Int?
  aiPinnedNoteChunkSize      Int?
  updatedAt              DateTime @updatedAt
}

model Role {
  id               String         @id @default(cuid())
  name             String
  title            String
  platform         String         @default("Slack")
  priority         Int
  color            String
  active           Boolean        @default(true)
  tone             String?
  context          String?
  responsibilities String?
  quarterlyGoals   String?
  aiRecentNotesCount         Int?
  aiRecentTranscriptsCount   Int?
  aiConversationHistoryLimit Int?
  aiNoteChunkSize            Int?
  aiTranscriptChunkSize      Int?
  aiPinnedNoteChunkSize      Int?
  staff         Staff[]
  tasks         Task[]
  meetings      Meeting[]
  followUps     FollowUp[]
  notes         Note[]
  transcripts   Transcript[]
  fileUploads   FileUpload[]
  conversations Conversation[]
  drafts        Draft[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Staff {
  id           String  @id @default(cuid())
  roleId       String
  role         Role    @relation(fields: [roleId], references: [id])
  name         String
  title        String
  relationship String?
  commNotes    String?
  email        String?
  slackHandle  String?
}

model Task {
  id         String    @id @default(cuid())
  roleId     String
  role       Role      @relation(fields: [roleId], references: [id])
  title      String
  priority   String    @default("normal")
  status     String    @default("backlog")
  isToday    Boolean   @default(false)
  done       Boolean   @default(false)
  doneAt     DateTime?
  notes      String?
  dueDate    DateTime?
  checklist  Json?
  tags          TaskTag[]
  files         TaskFile[]
  meeting       Meeting?
  conversations Conversation[]
  sortOrder     Int       @default(0)
  sourceType String?
  sourceId   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([roleId, done])
  @@index([isToday, done])
  @@index([roleId, status])
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  color String    @default("#888780")
  tasks TaskTag[]
}

model TaskTag {
  taskId String
  tagId  String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([taskId])
  @@index([tagId])
}

model FollowUp {
  id          String    @id @default(cuid())
  roleId      String
  role        Role      @relation(fields: [roleId], references: [id])
  title       String
  waitingOn   String
  status      String    @default("waiting")
  dueDate     DateTime?
  staleDays   Int       @default(3)
  resolvedAt  DateTime?
  sourceType  String?
  sourceId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([roleId, status])
}

model Note {
  id        String   @id @default(cuid())
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  content   String
  summary   String?
  tags      String[]
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  meeting   Meeting?

  @@index([roleId, createdAt])
  @@index([roleId, pinned])
}

model Transcript {
  id          String    @id @default(cuid())
  roleId      String
  role        Role      @relation(fields: [roleId], references: [id])
  title       String?
  rawText     String
  summary     String?
  sourceType  String?   // "granola", "manual", etc.
  sourceId    String?   // e.g. "granola-{noteId}" for dedup
  processedAt DateTime?
  meeting     Meeting?
  createdAt   DateTime  @default(now())
}

model FileUpload {
  id            String     @id @default(cuid())
  roleId        String
  role          Role       @relation(fields: [roleId], references: [id])
  filename      String
  mimeType      String
  size          Int
  storagePath   String
  extractedText String?
  summary       String?
  tasks         TaskFile[]
  createdAt     DateTime   @default(now())

  @@index([roleId])
}

model TaskFile {
  taskId String
  fileId String
  task   Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  file   FileUpload @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@id([taskId, fileId])
  @@index([taskId])
  @@index([fileId])
}

model Conversation {
  id        String   @id @default(cuid())
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  meetingId String?
  meeting   Meeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)
  name      String   @default("General")
  isDefault Boolean  @default(false)
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roleId, name])
  @@index([roleId, updatedAt])
  @@index([taskId])
  @@index([meetingId])
}

model ScheduleBlock {
  id             String   @id @default(cuid())
  label          String
  startHour      Int
  startMinute    Int
  endHour        Int
  endMinute      Int
  sortOrder      Int      @default(0)
  dayAssignments Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ScheduleOverride {
  id      String   @id @default(cuid())
  blockId String
  day     String
  roleId  String
  weekOf  DateTime
}

model Skill {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  description String
  icon        String?
  prompt      String
  category    String   @default("general")
  isBuiltIn   Boolean  @default(false)
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Integration {
  id             String    @id @default(cuid())
  type           String    @unique
  roleId         String
  config         Json
  enabled        Boolean   @default(true)
  lastSyncAt     DateTime?
  lastSyncResult String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Draft {
  id            String   @id @default(cuid())
  roleId        String
  role          Role     @relation(fields: [roleId], references: [id])
  recipientName String?
  platform      String?
  content       String
  status        String   @default("pending")
  createdAt     DateTime @default(now())

  @@index([roleId, status])
}

model SyncLog {
  id             String    @id @default(cuid())
  type           String    // "linear", "granola", "calendar"
  status         String    // "success", "error", "partial"
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  durationMs     Int?
  trigger        String    @default("manual") // "manual", "cron", "app-open"
  summary        String?
  errorMessage   String?
  itemsFound     Int?
  itemsCreated   Int?
  itemsUpdated   Int?
  itemsSkipped   Int?
  meta           Json?     // extra data (e.g. screenshot path, conflicts)
  createdAt      DateTime  @default(now())

  @@index([type, createdAt])
  @@index([createdAt])
}

model Meeting {
  id            String   @id @default(cuid())
  roleId        String
  role          Role     @relation(fields: [roleId], references: [id])
  title         String
  date          String
  startTime     String
  endTime       String
  attendees     String[]
  isIgnored     Boolean  @default(false)
  prepTaskId    String?  @unique
  prepTask      Task?    @relation(fields: [prepTaskId], references: [id])
  meetingNoteId  String?  @unique
  meetingNote    Note?    @relation(fields: [meetingNoteId], references: [id])
  transcriptId   String?  @unique
  transcript     Transcript? @relation(fields: [transcriptId], references: [id])
  aiPrepContent  String?
  followUpNotes  String?
  sourceId       String   @unique
  conversations  Conversation[]
  createdAt      DateTime @default(now())

  @@index([date, isIgnored])
}

model AiUsage {
  id           String   @id @default(cuid())
  roleId       String?
  endpoint     String
  model        String
  inputTokens  Int
  outputTokens Int
  costCents    Int
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([roleId])
}
